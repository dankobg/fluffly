{
	"name": "fluffly-web",
	"private": true,
	"version": "1.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite dev --host",
		"build": "vite build",
		"build-dev": "vite build --mode development",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test:unit": "vitest",
		"test": "pnpm test:unit -- --run && pnpm test:e2e",
		"test:e2e": "playwright test",
		"gen:openapi": "openapi-typescript --enum ../api/schema/fluffly.yaml -o ./src/lib/gen/fluffly_openapi.ts",
		"gen": "pnpm gen:openapi"
	},
	"devDependencies": {
		"@eslint/compat": "^1.4.0",
		"@eslint/js": "^9.38.0",
		"@internationalized/date": "^3.10.0",
		"@lucide/svelte": "^0.548.0",
		"@playwright/test": "^1.56.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.48.0",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@tailwindcss/forms": "^0.5.10",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.16",
		"@tanstack/table-core": "^8.21.3",
		"@types/node": "^24.9.1",
		"@vitest/browser": "^4.0.4",
		"bits-ui": "^2.14.1",
		"clsx": "^2.1.1",
		"eslint": "^9.38.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.12.5",
		"formsnap": "^2.0.1",
		"globals": "^16.4.0",
		"layerchart": "2.0.0-next.27",
		"openapi-typescript": "^7.10.1",
		"playwright": "^1.56.1",
		"prettier": "^3.6.2",
		"prettier-plugin-svelte": "^3.4.0",
		"prettier-plugin-tailwindcss": "^0.7.1",
		"svelte": "^5.42.2",
		"svelte-check": "^4.3.3",
		"svelte-sonner": "^1.0.5",
		"sveltekit-superforms": "^2.28.0",
		"tailwind-merge": "^3.3.1",
		"tailwind-variants": "^3.1.1",
		"tailwindcss": "^4.1.16",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.46.2",
		"vaul-svelte": "1.0.0-next.7",
		"vite": "^7.1.12",
		"vite-plugin-devtools-json": "^1.0.0",
		"vitest": "^4.0.4",
		"vitest-browser-svelte": "^2.0.1"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	},
	"dependencies": {
		"@ory/client-fetch": "^1.22.7",
		"just-safe-set": "^4.2.1",
		"mode-watcher": "^1.1.0",
		"openapi-fetch": "^0.15.0",
		"valibot": "^1.1.0"
	}
}

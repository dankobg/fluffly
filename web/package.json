{
	"name": "fluffly-web",
	"private": true,
	"version": "1.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite dev --host",
		"build": "vite build",
		"build-dev": "vite build --mode development",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test:unit": "vitest",
		"test": "pnpm test:unit -- --run && pnpm test:e2e",
		"test:e2e": "playwright test",
		"gen:openapi": "openapi-typescript --enum ../api/schema/fluffly.yaml -o ./src/lib/gen/fluffly_openapi.ts",
		"gen": "pnpm gen:openapi"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.3",
		"@eslint/js": "^10.0.1",
		"@internationalized/date": "^3.12.0",
		"@lucide/svelte": "^1.0.1",
		"@playwright/test": "^1.58.2",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@tanstack/table-core": "^8.21.3",
		"@types/node": "^25.5.0",
		"@vitest/browser": "^4.1.1",
		"@vitest/browser-playwright": "^4.1.1",
		"bits-ui": "2.16.3",
		"clsx": "^2.1.1",
		"eslint": "^10.1.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.16.0",
		"formsnap": "^2.0.1",
		"globals": "^17.4.0",
		"layerchart": "2.0.0-next.27",
		"openapi-typescript": "^7.13.0",
		"playwright": "^1.58.2",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.55.0",
		"svelte-check": "^4.4.5",
		"svelte-sonner": "^1.1.0",
		"sveltekit-superforms": "^2.30.0",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.2",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.1",
		"vaul-svelte": "1.0.0-next.7",
		"vite": "^8.0.2",
		"vite-plugin-devtools-json": "^1.0.0",
		"vitest": "^4.1.1",
		"vitest-browser-svelte": "^2.1.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	},
	"dependencies": {
		"@ory/client-fetch": "^1.22.28",
		"@uppy/core": "^5.2.0",
		"@uppy/dashboard": "^5.1.1",
		"@uppy/image-editor": "^4.2.0",
		"embla-carousel": "^8.6.0",
		"embla-carousel-svelte": "^8.6.0",
		"just-safe-set": "^4.2.1",
		"maplibre-gl": "^5.21.1",
		"mode-watcher": "^1.1.0",
		"openapi-fetch": "^0.17.0",
		"runed": "^0.37.1",
		"svelte-maplibre": "^1.2.6",
		"valibot": "^1.3.1"
	}
}

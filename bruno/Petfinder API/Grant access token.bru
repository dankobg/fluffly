meta {
  name: Grant access token
  type: http
  seq: 3
}

post {
  url: https://api.petfinder.com/v2/oauth2/token
  body: json
  auth: none
}

body:json {
  {
    "grant_type": "client_credentials",
    "client_id": "{{apiKey}}",
    "client_secret": "{{apiSecret}}"
  }
}

script:post-response {
  bru.setEnvVar("accessToken", res.body.access_token);
}

meta {
  name: Update animal
  type: http
  seq: 5
}

patch {
  url: {{baseUrl}}/animals/:id
  body: json
  auth: inherit
}

params:path {
  id: 1
}

body:json {
  {
    "age": "",
    "animal_species_id": 0,
    "animal_type_id": 0,
    "attributes": {},
    "breed_ids": [],
    "description": "",
    "gender": "",
    "hemaphrodite": false,
    "image_url": "",
    "name": "",
    "organization_id": 0,
    "size": "",
    "user_id": 0
  }
}
